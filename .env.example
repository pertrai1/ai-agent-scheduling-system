# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# Management API
PORT=3000

# Scheduler / rate-limit controls
# Maximum number of LLM calls that may run concurrently (default: 5)
MAX_CONCURRENT_LLM=5
# Milliseconds to wait between successive agent launches in the same tick (default: 500; 0 = disabled)
LLM_STAGGER_MS=500

# Application
NODE_ENV=development
LOG_LEVEL=info
